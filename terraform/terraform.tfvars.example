# Copy this file to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git (it contains secrets)

aws_region        = "eu-west-1"
project_name      = "mediaondemand"
environment       = "dev"
ec2_key_pair_name = "your-key-pair-name"
allowed_ssh_cidr  = "YOUR_IP/32"  # e.g. "203.0.113.50/32"
db_username       = "mediaadmin"
db_password       = "CHANGE_ME_strong_password_123!"

cognito_callback_urls = ["http://localhost:3000/callback"]
