# Environment variables for docker-compose
# Copy to .env and fill in with your values from Terraform outputs

AWS_REGION=eu-west-1
COGNITO_USER_POOL_ID=your-pool-id
COGNITO_APP_CLIENT_ID=your-client-id
DB_HOST=your-rds-endpoint
DB_USERNAME=mediaadmin
DB_PASSWORD=your-db-password
DB_NAME=mediaondemand
S3_RAW_BUCKET=mediaondemand-raw-xxxxxxxx
S3_PROCESSED_BUCKET=mediaondemand-processed-xxxxxxxx
CLOUDFRONT_DOMAIN=dxxxxxxxxxx.cloudfront.net
