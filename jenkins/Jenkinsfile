pipeline {
    agent any

    environment {
        AWS_REGION       = 'eu-west-1'
        PROJECT_NAME     = 'mediaondemand'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Rebuild') {
            steps {
                script {
                    dir('services') {
                        // Force rebuild to ensure code changes are picked up
                        sh 'docker-compose build --no-cache nginx catalog-service'
                        sh 'docker-compose build' 
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                script {
                    dir('services') {
                        sh 'docker-compose up -d --remove-orphans'
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sh 'sleep 10'
                    sh 'curl -f http://localhost:3000/health || echo "Frontend/Gateway might still be starting..."'
                    sh 'curl -f http://localhost:3002/health || exit 1' // Catalog is critical
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment successful! Website is live.'
        }
        failure {
            echo 'Deployment failed. Check logs.'
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}
