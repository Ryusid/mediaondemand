pipeline {
    agent any

    environment {
        AWS_REGION       = 'eu-west-1'
        PROJECT_NAME     = 'mediaondemand'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Deploy (Pull & Run)') {
            steps {
                script {
                    dir('services') {
                        // Pull the latest pre-built images from GitHub
                        sh 'docker-compose pull'
                        
                        // Start/Update the containers
                        sh 'docker-compose up -d --remove-orphans'
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    sh 'sleep 10'
                    sh 'curl -f http://localhost:3000/health || echo "Frontend/Gateway might still be starting..."'
                    sh 'curl -f http://localhost:3002/health || exit 1' // Catalog is critical
                }
            }
        }
    }

    post {
        success {
            echo 'Deployment successful! Application updated from GHCR.'
        }
        failure {
            echo 'Deployment failed. Check logs.'
        }
        always {
            // Clean up old unused images to save disk space
            sh 'docker image prune -af || true'
        }
    }
}
